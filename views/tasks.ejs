<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Tasks | TaskFlow</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root { --bg: #0d0f14; --surface: #151820; --surface2: #1c2030; --border: #252a3a; --accent: #6c63ff; --accent2: #ff6584; --text: #e8eaf0; --muted: #6b7280; --success: #34d399; --warning: #fbbf24; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
    
    /* Navigation */
    nav { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; border-bottom: 1px solid var(--border); background: var(--surface); }
    .nav-logo { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 1.3rem; color: var(--accent); text-decoration: none; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; }
    .nav-links a:hover, .nav-links a.active { color: var(--text); }
    .btn-logout { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 0.4rem 1rem; border-radius: 8px; font-size: 0.85rem; text-decoration: none; }
    
    /* Main Content */
    main { padding: 2.5rem 2rem; max-width: 1100px; margin: 0 auto; }
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .page-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 2rem; letter-spacing: -1px; }
    
    /* Buttons */
    .btn { display: inline-block; padding: 0.6rem 1.2rem; border-radius: 8px; font-size: 0.9rem; font-weight: 600; cursor: pointer; text-decoration: none; border: none; font-family: inherit; transition: opacity 0.2s; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-ghost { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
    .btn-danger { background: #3d1a1a; color: var(--accent2); border: 1px solid #5a2424; }
    .btn-sm { padding: 0.35rem 0.8rem; font-size: 0.8rem; }

    /* Task Cards */
    .task-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .task-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.2rem 1.5rem; display: flex; align-items: center; gap: 1rem; }
    .task-card.completed { opacity: 0.6; border-color: transparent; background: #11141b; }
    .task-info { flex: 1; min-width: 0; }
    .task-title { font-weight: 600; font-size: 1rem; margin-bottom: 0.25rem; }
    .task-meta { font-size: 0.8rem; color: var(--muted); display: flex; align-items: center; gap: 10px; }
    
    /* Badges */
    .badge { padding: 0.2rem 0.65rem; border-radius: 20px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; }
    .badge-pending { background: #2a2010; color: var(--warning); }
    .badge-completed { background: #0f2a1e; color: var(--success); }
    
    .task-actions { display: flex; gap: 0.5rem; align-items: center; }
    select { background: var(--surface2); border: 1px solid var(--border); color: var(--text); padding: 0.35rem; border-radius: 6px; font-size: 0.8rem; outline: none; }
  </style>
</head>
<body>
  <nav>
    <a href="/tasks/dashboard" class="nav-logo">TaskFlow</a>
    <div class="nav-links">
      <a href="/tasks/dashboard">Dashboard</a>
      <a href="/tasks" class="active">My Tasks</a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </nav>

  <main>
    <div class="page-header">
      <h1 class="page-title">My Tasks</h1>
      <a href="/tasks/add" class="btn btn-primary">+ New Task</a>
    </div>

    <% if (tasks.length === 0) { %>
      <div style="text-align: center; padding: 4rem; color: var(--muted);">
        <p>You don't have any tasks yet.</p>
        <br>
        <a href="/tasks/add" class="btn btn-ghost">Create your first task</a>
      </div>
    <% } else { %>
      <div class="task-list">
        <% tasks.forEach(task => { %>
          <div class="task-card <%= task.status === 'completed' ? 'completed' : '' %>">
            <div class="task-info">
              <div class="task-title"><%= task.title %></div>
              <div class="task-meta">
                <% if (task.dueDate) { %>
                  <span>Due: <%= new Date(task.dueDate).toLocaleDateString() %></span>
                  <span>•</span>
                <% } %>
                <span class="badge badge-<%= task.status %>"><%= task.status %></span>
              </div>
            </div>

            <div class="task-actions">
              <form method="POST" action="/tasks/status/<%= task.id %>">
                <select name="status" onchange="this.form.submit()">
                  <option value="pending" <%= task.status === 'pending' ? 'selected' : '' %>>Pending</option>
                  <option value="completed" <%= task.status === 'completed' ? 'selected' : '' %>>Completed</option>
                </select>
              </form>

              <form method="POST" action="/tasks/delete/<%= task.id %>" onsubmit="return confirm('Are you sure you want to delete this task?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>